# ============================================================
# Configuration du serveur MCP Outlook
# ============================================================
# Copiez ce fichier en .env et remplissez les valeurs
# Ne partagez JAMAIS votre fichier .env
# ============================================================

# Azure App Registration — recupéré dans le portail Azure
CLIENT_ID=votre-client-id-ici
TENANT_ID=votre-tenant-id-ici
CLIENT_SECRET=votre-client-secret-ici

# Callback OAuth (ne pas modifier sauf configuration avancee)
REDIRECT_URI=http://localhost:3333/callback

# Permissions Microsoft Graph (ne pas modifier)
SCOPES=Mail.Read,Mail.Send,User.Read,Calendars.ReadWrite
